---
import { classSchedule } from '../data/site';

const cardClass =
  'bg-white p-6 md:p-8 border border-gray-200 shadow-sm rounded-sm w-full min-h-[15rem] md:min-h-[16rem] flex flex-col';

const weds = classSchedule.find((entry) => entry.day === 'Weds');
const wedsFirst = weds?.classes[0];
const wedsMore = weds ? weds.classes.length - 1 : 0;
---

<section id="classes" class="py-24 bg-gray-50 reveal">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <h2 class="text-4xl md:text-5xl mb-12 md:mb-16 text-center text-black font-semibold">Classes</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 items-start">
      {
        classSchedule.map((entry) =>
          entry.day === 'Weds' ? (
            <article id="weds-card" class={cardClass}>
              <h3 class="text-sm font-semibold tracking-wide text-black mb-5">Weds</h3>
              <div class="flex flex-1 flex-col min-h-0">
                <div id="weds-preview" class="flex flex-1 flex-col min-h-0">
                  <div class="space-y-3 shrink-0">
                    <p class="text-gray-800 leading-relaxed">{wedsFirst?.name}</p>
                    <p class="text-gray-600 text-sm">{wedsFirst?.time}</p>
                    <p class="text-sm text-gray-500 pt-1">+ {wedsMore} more classes today</p>
                  </div>
                  <div class="flex-1 min-h-[1px]" aria-hidden="true" />
                </div>
                <div id="weds-panel">
                  <div class="space-y-4">
                    {entry.classes.map((cls) => (
                      <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
                        <p class="text-gray-800 leading-relaxed">{cls.name}</p>
                        <p class="text-gray-600 text-sm mt-1.5">{cls.time}</p>
                      </div>
                    ))}
                  </div>
                </div>
                <button
                  type="button"
                  id="weds-toggle"
                  class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 hover:text-gray-800 transition-colors shrink-0"
                  aria-expanded="false"
                  aria-controls="weds-panel"
                >
                  <span id="weds-toggle-label">View full Wednesday schedule</span>
                  <svg
                    id="weds-chevron"
                    class="w-4 h-4 shrink-0 text-gray-500 transition-transform duration-200"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
              </div>
            </article>
          ) : (
            <article class={cardClass}>
              <h3 class="text-sm font-semibold tracking-wide text-black mb-5">{entry.day}</h3>
              <div class="flex flex-1 flex-col min-h-0">
                <div class="space-y-4 shrink-0">
                  {entry.classes.map((cls) => (
                    <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
                      <p class="text-gray-800 leading-relaxed">{cls.name}</p>
                      <p class="text-gray-600 text-sm mt-1.5">{cls.time}</p>
                    </div>
                  ))}
                </div>
                <div class="flex-1 min-h-[1px]" aria-hidden="true" />
              </div>
            </article>
          )
        )
      }
    </div>
  </div>
</section>
