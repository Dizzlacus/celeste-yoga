---
import { Picture } from 'astro:assets';
import welcomeImage from '../assets/images/welcome.jpg';
---

<section id="contact" class="py-16 md:py-20 bg-gray-50 reveal">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <h2 class="text-4xl md:text-5xl mb-6 text-left text-black font-semibold">Contact Celeste</h2>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-10 md:gap-20 items-start">
      <div class="md:col-span-3">
        <div id="contact-form-block">
          <p class="text-sm text-gray-500 mb-6 max-w-md leading-relaxed">
            Even yogis need a pause sometimes. I occasionally step away from Instagram to return to
            myself — thank you for understanding.
          </p>

          <form
            id="contact-form"
            class="space-y-8"
            action="https://formspree.io/f/xnjllrza"
            method="POST"
          >
            <div>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                class="w-full px-4 py-4 bg-transparent border border-gray-300 text-black placeholder-gray-400 focus:outline-none focus:border-gray-600 transition-colors"
                placeholder="Name"
              />
            </div>
            <div>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-4 bg-transparent border border-gray-300 text-black placeholder-gray-400 focus:outline-none focus:border-gray-600 transition-colors"
                placeholder="Email"
              />
            </div>
            <div>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                class="w-full px-4 py-4 bg-transparent border border-gray-300 text-black placeholder-gray-400 focus:outline-none focus:border-gray-600 transition-colors resize-none"
                placeholder="Your message..."></textarea>
            </div>
            <div class="hidden" aria-hidden="true">
              <label for="website">Website</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>
            <div class="pt-4 text-left">
              <button
                type="submit"
                class="px-12 py-4 bg-black text-white hover:bg-gray-800 transition-colors tracking-wider text-sm"
              >
                SEND MESSAGE
              </button>
            </div>
          </form>
        </div>

        <div id="contact-success" class="hidden text-left py-12" role="status" aria-live="polite">
          <p class="text-2xl text-black mb-4">Thank you for reaching out</p>
          <p class="text-gray-600">I&rsquo;ll get back to you soon.</p>
        </div>
      </div>

      <div class="relative h-96 md:h-[500px] w-full md:col-span-2">
        <Picture
          src={welcomeImage}
          formats={['avif', 'webp']}
          alt="Celeste yoga pose"
          widths={[400, 600, 800]}
          sizes="(max-width: 767px) 100vw, 40vw"
          pictureAttributes={{ class: 'block h-full w-full' }}
          class="h-full w-full object-cover object-bottom opacity-80"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
