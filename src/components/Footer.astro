---
import { site } from '../data/site';
---

<footer class="py-16 px-6 md:px-12 bg-black">
  <div class="max-w-7xl mx-auto text-center">
    <p class="text-gray-400 mb-6 text-sm tracking-wide">GET IN TOUCH</p>
    <div class="flex flex-col gap-3 justify-center items-center mb-10">
      <a
        href={`mailto:${site.email}`}
        class="text-gray-300 hover:text-white transition-colors">{site.email}</a
      >
    </div>
    <p class="text-xs text-gray-500 tracking-wide mb-6">
      © <span id="footer-year"></span> CELESTE YOGA. ALL RIGHTS RESERVED.
    </p>
  </div>
</footer>
