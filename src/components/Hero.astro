---
import { getHeroImages } from '../utils/heroImages';

interface Props {
  id?: string;
  tagline?: string;
}

const { id = 'home', tagline } = Astro.props;
const { mobileAvif, mobileWebp, desktopAvif, desktopWebp, desktopFallback } = await getHeroImages();
---

<section
  id={id}
  class="page-hero relative min-h-screen flex items-center justify-center pt-16"
>
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <picture class="block w-full h-full">
      <source media="(max-width: 767px)" srcset={mobileAvif.src} type="image/avif" />
      <source media="(max-width: 767px)" srcset={mobileWebp.src} type="image/webp" />
      <source media="(min-width: 768px)" srcset={desktopAvif.src} type="image/avif" />
      <source media="(min-width: 768px)" srcset={desktopWebp.src} type="image/webp" />
      <img
        src={desktopFallback.src}
        alt=""
        width={desktopFallback.attributes.width}
        height={desktopFallback.attributes.height}
        class="w-full h-full object-cover opacity-60"
        decoding="sync"
        loading="eager"
        fetchpriority="high"
      />
    </picture>
  </div>
  <div class="relative z-10 text-center px-6">
    <h1 class="mb-8 md:mb-10">
      <img
        src="/logo.svg"
        alt="Celeste Yoga"
        width="608"
        height="472"
        class="mx-auto w-[min(70vw,14rem)] sm:w-[min(60vw,18rem)] md:w-[min(50vw,22rem)] h-auto"
        decoding="sync"
        fetchpriority="high"
      />
    </h1>
    {
      tagline ? (
        <p class="text-xl sm:text-2xl md:text-[50px] text-black tracking-wide font-semibold">{tagline}</p>
      ) : (
        <div
          class="flex flex-col md:flex-row md:flex-wrap items-center justify-center gap-y-2 md:gap-y-0 md:gap-x-4 text-lg md:text-2xl text-black tracking-wide"
        >
          <p>Yoga Teacher</p>
          <span
            class="hidden md:inline-block h-1.5 w-1.5 rounded-full bg-black"
            aria-hidden="true"
          ></span>
          <p>
            Rocket<sup class="text-[0.65em] -top-[0.15em]" aria-hidden="true">™</sup>
          </p>
          <span
            class="hidden md:inline-block h-1.5 w-1.5 rounded-full bg-black"
            aria-hidden="true"
          ></span>
          <p>Ashtanga</p>
          <span
            class="hidden md:inline-block h-1.5 w-1.5 rounded-full bg-black"
            aria-hidden="true"
          ></span>
          <p>Vinyasa</p>
        </div>
      )
    }
  </div>
</section>
