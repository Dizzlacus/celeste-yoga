---
interface Props {
  showMobileNav?: boolean;
  sticky?: boolean;
  homeLinks?: boolean;
}

const { showMobileNav = true, sticky = true, homeLinks = true } = Astro.props;

const links = homeLinks
  ? [
      { href: '/#welcome', label: 'Welcome' },
      { href: '/#classes', label: 'Classes' },
      { href: '/#about', label: 'About' },
      { href: '/#contact', label: 'Contact' },
    ]
  : [];
---

<nav
  class:list={[
    sticky
      ? 'fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-200'
      : 'w-full bg-white/95 backdrop-blur-sm border-b border-gray-200',
  ]}
  role="navigation"
  aria-label="Main navigation"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-4">
    <div class="flex justify-between items-center">
      <a
        href="/#home"
        class="text-xl tracking-wider text-black hover:text-gray-600 transition-colors bg-transparent border-0 cursor-pointer font-normal p-0"
      >
        Celeste Yoga
      </a>

      {
        homeLinks && (
          <div class="hidden md:flex gap-8">
            {links.map((link) => (
              <a
                href={link.href}
                class="text-sm tracking-wide text-gray-700 hover:text-black transition-colors"
              >
                {link.label}
              </a>
            ))}
          </div>
        )
      }

      {
        showMobileNav && homeLinks && (
          <button
            id="nav-burger"
            class="md:hidden relative flex items-center justify-center w-10 h-10 text-black"
            aria-expanded="false"
            aria-controls="nav-mobile-panel"
            aria-label="Toggle navigation menu"
          >
            <svg
              id="icon-hamburger"
              class="w-6 h-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg
              id="icon-close"
              class="w-6 h-6 is-hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        )
      }
    </div>

    {
      showMobileNav && homeLinks && (
        <div id="nav-mobile-panel" class="md:hidden border-t border-gray-100" aria-hidden="true">
          <div class="pt-4 pb-2">
            <div class="flex flex-col gap-4">
              {links.map((link) => (
                <a
                  href={link.href}
                  class="text-sm tracking-wide text-gray-700 hover:text-black transition-colors text-left py-0.5"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      )
    }
  </div>
</nav>
