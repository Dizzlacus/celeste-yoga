---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HeroPreload from '../components/HeroPreload.astro';
import { upcomingEvents } from '../data/site';
import aboutImage from '../assets/images/about.jpg';
import extraImage from '../assets/images/extra.jpg';
import welcomeImage from '../assets/images/welcome.jpg';

const eventImages: ImageMetadata[] = [extraImage, aboutImage, welcomeImage];
---

<BaseLayout
  title="Events — Celeste Yoga"
  description="Workshops, retreats and special events with Celeste Yoga in Newcastle."
>
  <HeroPreload slot="head" />
  <Hero id="events" tagline="Events" />

  {
    upcomingEvents.map((event, index) => {
      const imageOnLeft = index % 2 === 1;
      const image = eventImages[index] ?? extraImage;

      return (
        <section class="py-24 reveal">
          <div class="max-w-7xl mx-auto px-6 md:px-12">
            <div class="grid md:grid-cols-5 gap-16 md:gap-20 items-center">
              {
                imageOnLeft && (
                  <div class="relative h-96 md:h-[500px] w-full md:col-span-2">
                    <Picture
                      src={image}
                      formats={['avif', 'webp']}
                      alt={event.imageAlt}
                      widths={[400, 600, 800]}
                      sizes="(max-width: 767px) 100vw, 40vw"
                      pictureAttributes={{ class: 'block h-full w-full' }}
                      class="h-full w-full object-cover opacity-80"
                      loading="lazy"
                    />
                  </div>
                )
              }
              <div class="md:col-span-3">
                <h2 class="text-4xl md:text-5xl mb-6 text-black font-semibold">{event.title}</h2>
                <div class="text-gray-700 leading-relaxed space-y-4">
                  {event.description.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
                <dl class="mt-8 space-y-2 text-gray-700">
                  <div class="flex flex-wrap gap-x-2">
                    <dt class="font-medium text-black">When:</dt>
                    <dd>{event.date}</dd>
                  </div>
                  <div class="flex flex-wrap gap-x-2">
                    <dt class="font-medium text-black">Time:</dt>
                    <dd>{event.time}</dd>
                  </div>
                  <div class="flex flex-wrap gap-x-2">
                    <dt class="font-medium text-black">Where:</dt>
                    <dd>{event.location}</dd>
                  </div>
                  <div class="flex flex-wrap gap-x-2">
                    <dt class="font-medium text-black">Cost:</dt>
                    <dd>{event.cost}</dd>
                  </div>
                </dl>
                <div class="pt-8">
                  <a
                    href={event.bookingUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block px-12 py-4 bg-black text-white hover:bg-gray-800 transition-colors tracking-wider text-sm"
                  >
                    BOOK HERE
                  </a>
                </div>
              </div>
              {
                !imageOnLeft && (
                  <div class="relative h-96 md:h-[500px] w-full md:col-span-2">
                    <Picture
                      src={image}
                      formats={['avif', 'webp']}
                      alt={event.imageAlt}
                      widths={[400, 600, 800]}
                      sizes="(max-width: 767px) 100vw, 40vw"
                      pictureAttributes={{ class: 'block h-full w-full' }}
                      class={`h-full w-full object-cover opacity-80${index === 0 ? ' object-bottom' : ''}`}
                      loading="lazy"
                    />
                  </div>
                )
              }
            </div>
          </div>
        </section>
      );
    })
  }
</BaseLayout>
