---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import aboutImage from '../assets/images/about.jpg';
import extraImage from '../assets/images/extra.jpg';
import welcomeImage from '../assets/images/welcome.jpg';
---

<BaseLayout
  title="Events — Celeste Yoga"
  description="Workshops, retreats and special events with Celeste Yoga in Newcastle."
>
  <Hero id="events" tagline="Events" />

  <section class="py-24 reveal">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-5 gap-16 md:gap-20 items-center">
        <div class="md:col-span-3">
          <h2 class="text-4xl md:text-5xl mb-6 text-black font-semibold">Weekend Workshops</h2>
          <div class="text-gray-700 leading-relaxed space-y-4">
            <p>
              Dive deeper into your practice with immersive weekend workshops. Each session is
              designed to explore a focused theme — from alignment and breathwork to playful
              inversions and restorative resets.
            </p>
            <p>
              Suitable for all levels, these workshops offer space to ask questions, refine your
              technique, and leave feeling more connected to your body and breath.
            </p>
          </div>
        </div>
        <div class="relative h-96 md:h-[500px] w-full md:col-span-2">
          <Picture
            src={extraImage}
            formats={['avif', 'webp']}
            alt="Yoga workshop practice"
            widths={[400, 600, 800]}
            sizes="(max-width: 767px) 100vw, 40vw"
            pictureAttributes={{ class: 'block h-full w-full' }}
            class="h-full w-full object-cover object-bottom opacity-80"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 reveal">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-5 gap-14 md:gap-20 items-center">
        <div class="relative h-96 md:h-[560px] w-full md:col-span-2">
          <Picture
            src={aboutImage}
            formats={['avif', 'webp']}
            alt="Yoga retreat atmosphere"
            widths={[400, 600, 800]}
            sizes="(max-width: 767px) 100vw, 40vw"
            pictureAttributes={{ class: 'block h-full w-full' }}
            class="h-full w-full object-cover opacity-80"
            loading="lazy"
          />
        </div>
        <div class="md:col-span-3">
          <h2 class="text-4xl md:text-5xl mb-8 text-black font-semibold">Retreats</h2>
          <div class="space-y-6 text-gray-700 leading-relaxed">
            <p>
              Step away from the everyday with thoughtfully curated yoga retreats. Expect a mix of
              dynamic practice, quiet reflection, nourishing food, and time outdoors in beautiful
              settings.
            </p>
            <p>
              Whether you are looking for a short getaway or a longer immersion, retreats are a
              chance to reset, reconnect, and return home with a renewed sense of ease.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 reveal">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-5 gap-16 md:gap-20 items-center">
        <div class="md:col-span-3">
          <h2 class="text-4xl md:text-5xl mb-6 text-black font-semibold">Community Gatherings</h2>
          <div class="text-gray-700 leading-relaxed space-y-4">
            <p>
              Join seasonal community events — from open practices and guest teacher sessions to
              charity classes and celebration days. These gatherings are about connection as much as
              movement.
            </p>
            <p>
              Keep an eye on this page for upcoming dates. All are welcome, whether you are new to
              yoga or a long-time practitioner.
            </p>
          </div>
        </div>
        <div class="relative h-96 md:h-[500px] w-full md:col-span-2">
          <Picture
            src={welcomeImage}
            formats={['avif', 'webp']}
            alt="Community yoga gathering"
            widths={[400, 600, 800]}
            sizes="(max-width: 767px) 100vw, 40vw"
            pictureAttributes={{ class: 'block h-full w-full' }}
            class="h-full w-full object-cover opacity-80"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
