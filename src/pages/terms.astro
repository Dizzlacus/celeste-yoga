---
import BaseLayout from '../layouts/BaseLayout.astro';

const lastUpdated = new Date().toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Terms of Use — Celeste Yoga"
  description="Terms of use for the Celeste Yoga website."
  stickyNav={false}
>
  <main class="max-w-3xl mx-auto px-6 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-semibold text-neutral-900 mb-6">Terms of Use</h1>
    <p class="text-neutral-600 leading-relaxed mb-4">
      This is a placeholder terms of use page for the Celeste Yoga website. Replace this text with
      your own terms covering use of the site, class bookings, liability, and any other legal points
      relevant to your practice.
    </p>
    <p class="text-neutral-600 leading-relaxed mb-4">
      Last updated: {lastUpdated}
    </p>
    <div class="mt-10 pt-8 border-t border-neutral-200">
      <a href="/" class="text-sm text-neutral-600 hover:text-neutral-900 transition-colors"
        >Back to home</a
      >
    </div>
  </main>
</BaseLayout>
